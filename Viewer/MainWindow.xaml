<Window x:Class="Viewer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Image Viewer" Height="700" Width="1200"
        WindowStartupLocation="Manual"
        Background="#F0EEE6">
  <DockPanel>
    <Menu DockPanel.Dock="Top" Background="#F0EEE6" Foreground="#2B2A27">
      <MenuItem Header="ファイル(_F)">
        <MenuItem Header="終了(_X)" Click="Exit_Click" />
      </MenuItem>
      <MenuItem Header="ツール(_T)">
        <MenuItem Header="設定" Click="OpenSettings_Click" />
        <MenuItem Header="ショートカット設定" Click="OpenShortcuts_Click" />
      </MenuItem>
      <MenuItem Header="ヘルプ(_H)">
        <MenuItem Header="バージョン情報" Click="About_Click" />
      </MenuItem>
    </Menu>
    <Grid x:Name="RootGrid">
        <Grid.ColumnDefinitions>
            <!-- 左: フォルダーツリー（.NET ネイティブ） -->
            <ColumnDefinition x:Name="TreeCol" Width="250" MinWidth="120" />
            <ColumnDefinition Width="5" />
            <!-- 中央: ファイル一覧（WebView2） -->
            <ColumnDefinition Width="*" MinWidth="200" />
            <ColumnDefinition Width="5" />
            <!-- 右: 詳細（WebView2） -->
            <ColumnDefinition x:Name="DetailsCol" Width="320" MinWidth="200" />
        </Grid.ColumnDefinitions>

        <!-- フォルダーツリー（シェル名前空間, 仕様 §1.2 / C.6）。
             将来シェル名前空間（PC/ライブラリ/ネットワーク）へ拡張（仕様 §1.2）。 -->
        <TreeView x:Name="FolderTree"
                  Grid.Column="0"
                  Background="#F0EEE6" Foreground="#2B2A27" BorderThickness="0"
                  Padding="0,4,0,0"
                  SelectedItemChanged="FolderTree_SelectedItemChanged"
                  TreeViewItem.Expanded="FolderTree_Expanded"
                  PreviewMouseDown="FolderTree_PreviewMouseDown"
                  PreviewMouseRightButtonDown="FolderTree_PreviewMouseRightButtonDown">
            <TreeView.Resources>
                <!-- フォーカスが無いとき（一覧移動でプログラム選択された等）の選択色を、
                     クリック選択時と同じハイライト色にする（既定の薄いグレーだと背景と紛らわしいため）。 -->
                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}"
                                 Color="{x:Static SystemColors.HighlightColor}" />
                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}"
                                 Color="{x:Static SystemColors.HighlightTextColor}" />
                <Style TargetType="TreeViewItem">
                    <Setter Property="Foreground" Value="#2B2A27" />
                    <!-- 各アイテムの上下に余白（≒1/4ライン）を入れて隙間を開ける -->
                    <Setter Property="Padding" Value="2,2,2,2" />
                </Style>
            </TreeView.Resources>
        </TreeView>

        <!-- ペイン境界：1px の細線（表示）＋透明の 5px グラブ領域（リサイズ）を同じ列に重ねる -->
        <Border Grid.Column="1" Width="1" Background="#E0DCD0" HorizontalAlignment="Center" />
        <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="Transparent" />

        <!-- 中央: タブ化されたファイル一覧。タブバーは WPF（見出しのみ）、各タブの中身は
             TabContentHost に常駐する WebView2（切替は Visibility のみ・付け替えない）。 -->
        <DockPanel Grid.Column="2">
            <Border DockPanel.Dock="Top" Background="#E8E5DB"
                    BorderBrush="#E0DCD0" BorderThickness="0,0,0,1">
                <!-- 横幅に入りきらない数のタブは複数段に折り返す（WrapPanel）。段が増えすぎたら
                     縦スクロール（横スクロールは無効＝幅で折り返させる）。＋ ボタンは末尾に維持。 -->
                <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto"
                              MaxHeight="160">
                    <WrapPanel x:Name="TabStripPanel" Orientation="Horizontal" />
                </ScrollViewer>
            </Border>
            <Grid x:Name="TabContentHost" />
        </DockPanel>

        <Border Grid.Column="3" Width="1" Background="#E0DCD0" HorizontalAlignment="Center" />
        <GridSplitter Grid.Column="3" Width="5" HorizontalAlignment="Stretch" Background="Transparent" />

        <!-- 右: 詳細（タブごとの WebView2 が常駐。切替は Visibility のみ） -->
        <Grid x:Name="DetailsHost" Grid.Column="4" />
    </Grid>
  </DockPanel>
</Window>
